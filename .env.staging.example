# Lorekeeper / Lorebook — STAGING environment template
# Copy to .env.staging.local (gitignored) or use .private/staging-credentials.env
# NEVER point these at production (lorebookai.com / production Supabase ref).

API_ENV=staging
NODE_ENV=production

# Isolated staging Supabase project (NOT production)
STAGING_SUPABASE_PROJECT_REF=your-staging-project-ref
STAGING_SUPABASE_URL=https://YOUR_STAGING_REF.supabase.co
STAGING_SUPABASE_ANON_KEY=your-staging-anon-key
STAGING_SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key

# Direct + pooler database URLs (staging project only)
STAGING_DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_STAGING_REF.supabase.co:5432/postgres
STAGING_DATABASE_POOLER_URL=postgresql://postgres.YOUR_STAGING_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Hosted staging API + web (provision separately; do not use production Railway/Vercel URLs)
STAGING_API_URL=https://YOUR-STAGING-API.up.railway.app
STAGING_APP_URL=https://staging.lorebookai.com

# Staging-only automated test user (no real PII)
STAGING_TEST_USER_EMAIL=staging-qual+auto@example.test
STAGING_TEST_USER_PASSWORD=replace-with-long-random-password

# Optional server aliases when running against staging
# DATABASE_URL should NOT be set here from production — use STAGING_* only in qual scripts
# SUPABASE_URL=${STAGING_SUPABASE_URL}
# SUPABASE_ANON_KEY=${STAGING_SUPABASE_ANON_KEY}
# SUPABASE_SERVICE_ROLE_KEY=${STAGING_SUPABASE_SERVICE_ROLE_KEY}

# Safety defaults for staging hosts
SENTRY_ENVIRONMENT=staging
DURABILITY_FAULT_INJECTION=0
RAILWAY_ENVIRONMENT=staging
