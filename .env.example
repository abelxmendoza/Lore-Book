# Lore Keeper unified environment
PORT=4000
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_MODEL=gpt-4o-mini
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EXTRACTION_MODEL=gpt-4o-mini
OPENAI_NANO_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Responses API (recommended). Set OPENAI_USE_RESPONSES=false to revert to Chat Completions.
# OPENAI_CHAT_USE_RESPONSES=false disables only the streaming chat path.
# Primary (custom domain; requires Supabase Custom Domains add-on ~$10/mo):
SUPABASE_URL=https://supabase.lorebookai.com
# Optional explicit fallback. If omitted, boot/runtime derives https://<project_ref>.supabase.co
# from the anon key JWT automatically when the custom domain is unreachable.
# SUPABASE_URL_FALLBACK=https://cshtthzpgkmrbcsfghyq.supabase.co
SUPABASE_ANON_KEY=public-anon-key
SUPABASE_SERVICE_ROLE_KEY=service-role-key
# @supabase/server SDK names. Prefer these for new server-context code; legacy
# SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY remain supported by the adapter.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_JWKS_URL=https://supabase.lorebookai.com/auth/v1/.well-known/jwks.json
# Fallback JWKS: https://cshtthzpgkmrbcsfghyq.supabase.co/auth/v1/.well-known/jwks.json
# X integration. Backend only; never expose these as VITE_* variables.
X_API_BEARER_TOKEN=your-x-bearer-token
X_API_CONSUMER_KEY=your-x-consumer-key
X_API_CONSUMER_SECRET=your-x-consumer-secret
# Optional default account for External Hub sync. You can also pass { "handle": "..." }.
X_API_HANDLE=your_x_handle_without_at
# X_API_USER_ID=1234567890

# Migrations (npm run migrate:base): Session pooler REQUIRED. Username must be postgres.<project_ref> (not plain "postgres"). No sslmode= in URI.
# Copy from: Supabase Dashboard → Settings → Database → Connection string (URI) → Session mode, then remove ?sslmode=... if present.
# SUPABASE_CONNECTION_STRING=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Direct Postgres for Drizzle / bulk jobs / vector search.
# Transaction pooler requires prepared statements disabled; the Drizzle client does this.
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_POOLER_TRANSACTION_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_POOLER_SESSION_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres
POSTGRES_POOL_MAX=10
POSTGRES_IDLE_TIMEOUT_SECONDS=20
POSTGRES_CONNECT_TIMEOUT_SECONDS=10

# ── Platform roles (owner / admin / developer) ───────────────────────────────
# Owner (founder): permanent platform authority — never billed, never downgraded.
#   OWNER_EMAIL / FOUNDER_EMAIL — primary founder account (e.g. abelxmendoza@gmail.com)
#   OWNER_USER_ID / FOUNDER_USER_ID — optional UUID override
# Admin: full application access, premium without billing.
#   ADMIN_EMAIL, ADMIN_USER_ID
# Developer: test account, premium without billing.
#   DEVELOPER_EMAIL — e.g. firefistabel@gmail.com
# Roles can also be set in Supabase: app_metadata.role = owner|admin|developer
OWNER_EMAIL=
FOUNDER_EMAIL=
OWNER_USER_ID=
DEVELOPER_EMAIL=
ADMIN_EMAIL=
ADMIN_USER_ID=

# Frontend role env (Vite) — mirror server values in Vercel dashboard:
# VITE_OWNER_EMAIL, VITE_DEVELOPER_EMAIL, VITE_ADMIN_EMAIL, VITE_ADMIN_USER_ID

# ── Stripe subscription billing ───────────────────────────────────────────────
# Server-side (keep secret — never expose to the client / commit a real value):
#   STRIPE_SECRET_KEY      sk_test_… in dev, sk_live_… in prod
#   STRIPE_WEBHOOK_SECRET  whsec_… — from the Stripe webhook endpoint, or from
#                          `stripe listen` during local testing
#   SUBSCRIPTION_PRICE_ID  price_… — the recurring Price for the premium tier
#                          (create a Product + Price in the Stripe Dashboard)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
SUBSCRIPTION_PRICE_ID=price_xxx
# Publishable key (safe to expose). STRIPE_PUBLISHABLE_KEY is read by the server
# config; VITE_STRIPE_PUBLISHABLE_KEY is what the web app actually uses.
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Frontend (Vite) expects the VITE_ prefix
VITE_SUPABASE_URL=https://supabase.lorebookai.com
# VITE_SUPABASE_URL_FALLBACK=https://cshtthzpgkmrbcsfghyq.supabase.co
VITE_SUPABASE_ANON_KEY=public-anon-key
VITE_API_URL=http://localhost:4000
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Early-access disclaimer modal on first visit (set false to hide)
# VITE_SHOW_DEV_NOTICE=false

# ── Public launch (manual dashboard steps) ───────────────────────────────────
# 1. Stripe live: sk_live_ + pk_live_ on Railway/Vercel; live webhook in Stripe Dashboard
# 2. Google OAuth: consent screen → In production; redirect URIs for both Supabase URLs
# 3. Deploy: Railway (bootstrap.js) + Vercel redeploy after env changes
# 4. Verify: npm run prelaunch:smoke
# True-MVP diagnostic (3-day recall chain against prod Supabase):
# LOREKEEPER_TEST_USER_ID=<uuid>
# Backend: skip Supabase JWT check for all API routes. Hard-fails if set in production.
# DISABLE_AUTH_FOR_DEV=true
#
# Backend: return labelled fallback responses when OpenAI returns 429/timeout.
# Keeps UI development working without a valid OpenAI key. Hard-fails in production.
# DEV_AI_FALLBACK=true
#
# ── OpenAI Agent Skills (admin shell agent) ───────────────────────────────────
# Upload: npm run openai-skills:sync  →  copy IDs from openai-skills/manifest.json
# OPENAI_SKILLS_AGENT_ENABLED=true
# OPENAI_AGENT_MODEL=gpt-5.4
# OPENAI_SKILL_CHARACTER_CARD_AUDIT_ID=skill_xxx
# OPENAI_SKILL_RESCAN_OPS_ID=skill_xxx
#
# ── OpenAI platform (opt-in; all default off) ─────────────────────────────────
# OPENAI_RESPONSE_CHAINING=true
# OPENAI_CONVERSATIONS_API=true
# OPENAI_BACKGROUND_RESPONSES=true
# OPENAI_VECTOR_STORE_ENABLED=true
# OPENAI_VECTOR_STORE_ID=vs_xxx
# OPENAI_USE_COMPACT_API=true
# OPENAI_COMPACT_THRESHOLD=200000
# OPENAI_PROMPT_CACHE_RETENTION=24h
# OPENAI_USE_INPUT_TOKEN_COUNT=false
# OPENAI_WEBHOOK_SECRET=whsec_xxx
#
# Cost guard — platform-wide monthly OpenAI spend cap (USD). Default $5 in production, 0 in dev.
# MONTHLY_OPENAI_BUDGET_USD=5
# FREE_TIER_AI_LIMIT=30
#
# Lore-based character portraits (OpenAI Images — costly; DEFERRED, default off)
# DiceBear avatars are used until this is enabled for unique lore-context portraits.
# ENABLE_LORE_AVATARS=true
# AVATAR_IMAGE_MODEL=gpt-image-1
#
# Frontend: skip AuthGate (put this in apps/web/.env.local, not here).
# VITE_DEV_DISABLE_AUTH=true
#
# ── LoreBook MCP memory platform ─────────────────────────────────────────────
# Exposes read-only memory tools at POST/GET /mcp (Streamable HTTP).
# ENABLE_MCP=true
# MCP_READ_RPM_FREE=60
# MCP_READ_RPM_PREMIUM=300
# MCP_CHATGPT_IP_ALLOWLIST=true
# OAuth 2.1 for ChatGPT Developer mode (authorization code + PKCE)
# ENABLE_MCP_OAUTH=true
# MCP_OAUTH_ISSUER=https://lore-book-production.up.railway.app
# MCP_RESOURCE_AUDIENCE=mcp.lorebookai.com
# MCP_OAUTH_JWT_SECRET=generate-a-long-random-secret
# MCP_OAUTH_ACCESS_TTL_SEC=900
# MCP_WEB_APP_URL=https://lorebookai.com
# Local stdio client (Cursor): set cwd to apps/server in .cursor/mcp.json — npm run mcp:stdio
# MCP_DEV_USER_ID=
