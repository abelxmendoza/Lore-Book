{
  "name": "lorekeeper",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"web,server\" -c \"cyan,green\" \"npm run dev:web\" \"npm run dev:server\"",
    "dev:web": "cd apps/web && npm run dev",
    "dev:server": "cd apps/server && npm run dev",
    "validate": "node scripts/validate.mjs",
    "smoke": "node scripts/smoke.mjs",
    "check:supabase": "node scripts/check-supabase.mjs",
    "test:security": "cd apps/server && npm test middleware/ integration/privacy.test.ts",
    "test:e2e:security": "cd apps/web && npm run test:e2e:security",
    "test:all": "npm run test:security && npm run test:e2e:security",
    "find-unused": "cd apps/server && node scripts/find-unused-code.js",
    "lint:fix": "cd apps/server && npm run lint -- --fix && cd ../web && npm run lint -- --fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7"
  }
}
