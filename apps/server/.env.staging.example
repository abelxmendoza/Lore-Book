# Lorekeeper API / worker — staging only
# Copy to apps/server/.env.staging.local (gitignored)
# Do not reuse production secrets.

API_ENV=staging
NODE_ENV=production
PORT=4000

# Staging Supabase (project ref must NOT be production)
SUPABASE_URL=https://YOUR_STAGING_REF.supabase.co
SUPABASE_ANON_KEY=your-staging-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_STAGING_REF.supabase.co:5432/postgres

# Staging-budget OpenAI key (separate from production usage)
OPENAI_API_KEY=sk-staging-or-budget-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EXTRACTION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Observability
SENTRY_ENVIRONMENT=staging
# SENTRY_DSN=optional-staging-dsn

# Durability safety — keep disabled unless intentionally testing recovery
DURABILITY_FAULT_INJECTION=0

# Platform identity
RAILWAY_ENVIRONMENT=staging
