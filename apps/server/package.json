{
  "name": "server",
  "version": "0.1.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/bootstrap.ts",
    "sync:legal": "mkdir -p legal && (cp -f ../../legal/TERMS.md ../../legal/PRIVACY.md legal/ 2>/dev/null || true) && test -f legal/TERMS.md && test -f legal/PRIVACY.md",
    "prebuild": "npm run sync:legal",
    "build": "tsc --project tsconfig.json || true",
    "postbuild": "mkdir -p dist/legal && cp -f legal/TERMS.md legal/PRIVACY.md dist/legal/",
    "start": "node dist/bootstrap.js",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ingestion": "vitest run tests/services/extractionSignals.test.ts tests/utils/aiUncertainty.test.ts tests/services/ingestionPipeline.test.ts tests/integration/ingestionPipelineE2E.test.ts",
    "test:egress": "vitest run tests/architecture/egressProjection.test.ts tests/architecture/organizationProjection.test.ts tests/services/ingestionDedupCache.test.ts tests/services/semanticConversionReuse.test.ts tests/services/organizationServiceCache.test.ts",
    "test:scripts": "vitest run tests/scripts/migrationRunner.test.ts tests/scripts/migrate.test.ts tests/scripts/backfillScores.test.ts tests/scripts/cleanupLegacyEntities.test.ts",
    "test:audits": "vitest run tests/scripts/auditCommon.test.ts tests/scripts/auditDispatcher.test.ts tests/architecture/preDeletionReferences.test.ts",
    "test:phase1": "vitest run tests/services/timelineV2Service.test.ts tests/integration/timelineV2Redirect.integration.test.ts tests/services/chat/foundationEntityIndex.test.ts tests/integration/peoplePlacesReadRedirect.integration.test.ts tests/services/chat/recallQueryRouter.test.ts tests/services/chat/memoryClaimGuard.test.ts tests/services/chat/contextAwareMemoryRetrieval.test.ts tests/services/chat/characterCreationVerification.test.ts tests/services/chat/memoryFormationStatus.test.ts tests/services/workingMemoryAssembler.test.ts tests/architecture/preDeletionReferences.test.ts",
    "test:kinship": "vitest run tests/services/kinshipConsolidation.unit.test.ts tests/services/kinshipGlossarySSOT.test.ts tests/services/kinshipInference.test.ts tests/services/familyGraphService.test.ts tests/services/glossaryIntegrity.test.ts tests/services/familyGraphInference.integration.test.ts tests/integration/kinshipGraphE2E.test.ts",
    "test:stance": "vitest run tests/services/preferenceStance.test.ts tests/services/epistemicStance.test.ts tests/services/affectStance.test.ts tests/services/stanceGlossarySSOT.test.ts tests/services/revealedPreference.test.ts",
    "test:lexical": "vitest run tests/services/temporalLexicon.test.ts tests/services/socialRelationshipIntelligence.test.ts tests/services/discourseStance.test.ts tests/services/narrativeStructureBridge.test.ts tests/services/narrativeSegmentationStructure.test.ts tests/services/narrativeArcConsolidation.test.ts tests/services/narrativeArcConsolidationScheduler.test.ts tests/services/messageLexicalMetadataService.test.ts tests/services/glossaryIntegrity.test.ts",
    "test:lore-agents": "vitest run tests/services/agents tests/routes/loreAgentsRoute.test.ts tests/services/personaRegistry.test.ts tests/services/chat/systemPromptEvidence.test.ts tests/integration/loreAgentRouting.integration.test.ts",
    "test:system-cognition": "vitest run tests/services/chat/lorebookSelfModelService.test.ts tests/services/chat/lorebookSelfModelService.db.test.ts tests/services/chat/systemCognitionIntentMatrix.test.ts tests/services/chat/systemPromptEvidence.test.ts tests/db/systemKnowledgeProductSeed.test.ts tests/architecture/systemCognitionWiring.test.ts",
    "test:composer-chips": "vitest run tests/services/entityMentionIndex.test.ts tests/routes/entityComposer.test.ts tests/integration/composerEntitiesChat.integration.test.ts",
    "test:lorebook-parse": "vitest run tests/services/lorebookParser tests/routes/lorebookParseRoute.test.ts tests/routes/loreBookNoticeRoute.test.ts tests/integration/loreBookParsePipeline.integration.test.ts tests/integration/loreBookNoticePipeline.integration.test.ts",
    "test:governance": "vitest run tests/services/claimGovernanceBridge.test.ts tests/services/omegaMemoryMrqGovernance.test.ts tests/services/ingestionMemoryBridge.test.ts tests/integration/mrqClaimGovernance.integration.test.ts tests/integration/governancePipelineE2E.test.ts",
    "test:temporal": "vitest run tests/utils/temporalResolver.test.ts tests/utils/temporalNormalization.test.ts tests/integration/temporalResolverMigration.integration.test.ts",
    "test:narrative-cognition": "vitest run src/services/cognition src/services/narrativeSpine src/services/conversationCentered/eventCausalDetector.cognition.test.ts src/services/characters/characterLoreProfileService.test.ts tests/routes/cognition.test.ts tests/integration/cognitionPipeline.integration.test.ts tests/integration/cognitionGraphE2E.test.ts",
    "check-env": "tsx scripts/check-env.ts",
    "cost:ingestion": "node scripts/aggregate-ingestion-cost.mjs",
    "capture:ingestion-sample": "bash scripts/capture-ingestion-sample.sh",
    "typecheck": "tsc --noEmit",
    "runtime-health": "tsx scripts/runtime-health.ts",
    "mvp-diagnostic": "tsx scripts/true-mvp-diagnostic.ts",
    "egress:rowsize": "tsx scripts/measure-egress-rowsize.ts",
    "egress:simulate": "tsx scripts/simulate-egress.ts",
    "mcp:stdio": "tsx src/mcp/stdio.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.108.2",
    "chrono-node": "^2.9.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.1.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "openai": "^6.44.0",
    "p-queue": "^9.3.0",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "stripe": "^20.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^5.5.4",
    "uuid": "^13.0.0",
    "ws": "^8.21.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^26.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-node": "^11.1.0",
    "supertest": "^7.1.4",
    "tsx": "^4.16.2",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "minimatch": "^9.0.9",
    "brace-expansion": "^2.1.1",
    "swagger-ui-dist": "^5.32.6",
    "qs": "^6.15.1",
    "path-to-regexp": "^8.4.2",
    "@xmldom/xmldom": "^0.8.13",
    "picomatch": "^4.0.4",
    "flatted": "^3.4.2",
    "underscore": "^1.13.8"
  }
}
