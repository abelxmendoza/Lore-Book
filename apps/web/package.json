{
  "name": "web",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/vercel-build-diagnostics.js",
    "build": "vite build --logLevel info",
    "postbuild": "node scripts/post-build-validation.js",
    "build:verbose": "vite build --logLevel verbose",
    "preview": "vite preview",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage --config vitest.config.coverage.ts",
    "test:coverage:check": "vitest run --coverage --config vitest.config.coverage.ts && npm run test:coverage:threshold",
    "test:coverage:threshold": "node scripts/check-coverage-threshold.js",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:vitest": "vitest run && vitest run --config vitest.integration.config.ts",
    "test:build": "node scripts/build-validation.test.js",
    "test:chunk-deps": "node scripts/chunk-dependency-check.js",
    "test:black-screen": "vitest run --config vitest.integration.config.ts src/**/*.integration.test.tsx src/**/*.integration.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:production": "playwright test e2e/production-build.spec.ts",
    "test:e2e:security": "start-server-and-test dev http://localhost:5173 test:e2e:security:run",
    "test:e2e:security:run": "E2E_EXTERNAL_SERVER=1 playwright test e2e/security.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "cypress:run": "cypress run",
    "test:cypress": "start-server-and-test dev http://localhost:5173 cypress:run",
    "test:cypress:open": "cypress open",
    "install:skip-cypress-binary": "CYPRESS_INSTALL_BINARY=0 npm install",
    "install:foreground-scripts": "npm install --foreground-scripts",
    "cypress:install-binary": "npx cypress install",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:black-screen && npm run test:e2e && npm run test:cypress",
    "test:pre-deploy": "npm run test:unit && npm run test:black-screen && npm run build && npm run test:build && npm run test:chunk-deps"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@remix-run/router": "^1.23.2",
    "@sentry/react": "^10.45.0",
    "@sentry/tracing": "^7.120.4",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.11.0",
    "@supabase/supabase-js": "^2.100.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@vitejs/plugin-react": "^6.0.1",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "highlight.js": "^11.11.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.0.1",
    "posthog-js": "^1.363.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-force-graph-2d": "^1.29.1",
    "react-hook-form": "^7.72.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "react-simple-code-editor": "^0.14.1",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "vis-data": "^8.0.3",
    "vis-timeline": "^8.5.0",
    "vite": "^8.0.2",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "preact": "^10.28.2",
    "esbuild": "^0.25.0",
    "tailwindcss": "3.4.17"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/cypress": "^10.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.1",
    "@vitest/ui": "^4.1.1",
    "autoprefixer": "^10.4.27",
    "cypress": "^15.12.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "start-server-and-test": "^2.1.5",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "3.4.17",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1",
    "wait-on": "^9.0.3"
  }
}
