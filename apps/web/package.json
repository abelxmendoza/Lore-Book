{
  "name": "web",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/vercel-build-diagnostics.js",
    "build": "vite build --logLevel info",
    "postbuild": "node scripts/post-build-validation.js",
    "build:verbose": "vite build --logLevel verbose",
    "preview": "vite preview",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage --config vitest.config.coverage.ts",
    "test:coverage:check": "vitest run --coverage --config vitest.config.coverage.ts && npm run test:coverage:threshold",
    "test:coverage:threshold": "node scripts/check-coverage-threshold.js",
    "test:unit": "vitest run",
    "test:composer-chips": "vitest run src/lib/certifiedEntityMatch.test.ts src/store/slices/composerSlice.test.ts src/features/chat/composer/ComposerEntityChips.test.tsx src/features/chat/composer/composerFlow.integration.test.tsx src/features/chat/hooks/useChatComposer.test.tsx src/hooks/useEntityIndexer.test.tsx src/features/chat/hooks/__tests__/useChat.entities.test.tsx",
    "test:lorebook-parse": "vitest run src/lib/loreBookParse*.test.ts src/lib/loreBookNotice*.test.ts src/hooks/useEntityIndexer.test.tsx src/features/chat/composer/loreBookComposerFlow.integration.test.tsx && vitest run --config vitest.integration.config.ts src/lib/loreBookParsePipeline.integration.test.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:vitest": "vitest run && vitest run --config vitest.integration.config.ts",
    "test:build": "node scripts/build-validation.test.js",
    "test:demo-privacy": "node scripts/check-demo-data-privacy.cjs",
    "test:chunk-deps": "node scripts/chunk-dependency-check.js",
    "test:black-screen": "vitest run --config vitest.integration.config.ts src/**/*.integration.test.tsx src/**/*.integration.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:production": "playwright test e2e/production-build.spec.ts",
    "test:e2e:production-site": "PLAYWRIGHT_BASE_URL=https://lorebookai.com playwright test e2e/production-site.spec.ts --project=chromium",
    "test:e2e:security": "start-server-and-test dev http://localhost:5173 test:e2e:security:run",
    "test:e2e:security:run": "E2E_EXTERNAL_SERVER=1 playwright test e2e/security.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "cypress:run": "cypress run",
    "test:cypress": "start-server-and-test dev http://localhost:5173 cypress:run",
    "test:cypress:open": "cypress open",
    "install:skip-cypress-binary": "CYPRESS_INSTALL_BINARY=0 npm install",
    "install:foreground-scripts": "npm install --foreground-scripts",
    "cypress:install-binary": "npx cypress install",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:black-screen && npm run test:e2e && npm run test:cypress",
    "test:pre-deploy": "npm run test:unit && npm run test:black-screen && npm run test:demo-privacy && npm run build && npm run test:build && npm run test:chunk-deps"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-tabs": "^1.1.17",
    "@reduxjs/toolkit": "^2.12.0",
    "@remix-run/router": "^1.23.2",
    "@sentry/react": "^10.66.0",
    "@stripe/react-stripe-js": "^5.4.0",
    "@stripe/stripe-js": "^9.10.0",
    "@supabase/supabase-js": "^2.110.7",
    "@tanstack/react-virtual": "^3.14.6",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dompurify": "^3.4.12",
    "highlight.js": "^11.11.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.439.0",
    "moment": "^2.30.1",
    "postcss": "^8.5.19",
    "posthog-js": "^1.404.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph-2d": "^1.29.1",
    "react-hook-form": "^7.81.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.3.0",
    "react-router-dom": "^6.30.4",
    "react-simple-code-editor": "^0.14.1",
    "reactflow": "^11.11.4",
    "recharts": "^2.12.7",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.3.0",
    "tailwindcss": "3.4.17",
    "vis-data": "^8.0.3",
    "vis-timeline": "^8.5.2",
    "vite": "^7.3.5",
    "zod": "^4.3.6",
    "zustand": "^4.5.4"
  },
  "overrides": {
    "preact": "^10.28.2",
    "esbuild": "^0.28.1",
    "tailwindcss": "3.4.17",
    "picomatch": "^2.3.2",
    "uuid": "^11.1.1",
    "minimatch": "^9.0.9",
    "brace-expansion": "^2.1.1",
    "follow-redirects": "^1.16.0",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "protobufjs": "^7.5.5",
    "flatted": "^3.4.2",
    "ajv": "^6.14.0",
    "yaml": "^2.8.3",
    "qs": "^6.15.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/cypress": "^10.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.9",
    "cypress": "^15.18.1",
    "esbuild": "^0.28.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-cypress": "^2.15.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "jsdom": "^25.0.1",
    "msw": "^2.15.0",
    "prettier": "^3.9.5",
    "start-server-and-test": "^2.0.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  }
}
