# Lorebook web — staging / preview only
# Copy to apps/web/.env.staging.local (gitignored)
# Bundle must never include service-role keys or database credentials.

VITE_API_ENV=staging
VITE_APP_URL=https://staging.lorebookai.com
VITE_API_URL=https://YOUR-STAGING-API.up.railway.app
VITE_SUPABASE_URL=https://YOUR_STAGING_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-staging-anon-key

# Do NOT set:
# VITE_SUPABASE_SERVICE_ROLE_KEY
# VITE_DATABASE_URL
# VITE_DURABILITY_FAULT_INJECTION
